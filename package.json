{
  "name": "moltworms",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @moltworms/web",
    "dev:api": "npm run dev -w @moltworms/api",
    "dev:worker": "npm run dev -w @moltworms/worker",
    "build": "npm run build -ws",
    "lint": "npm run lint -ws",
    "test": "npm run test -ws"
  },
  "services/worker": {
    "dependencies": {
      "node-telegram-bot-api": "^0.66.0"
    }
  }
}
