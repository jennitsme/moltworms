generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  accounts    Account[]
  channels    Channel[]
  approvals   Approval[]
}

model Account {
  id            String   @id @default(cuid())
  provider      String
  providerId    String
  accessToken   String?
  refreshToken  String?
  expiresAt     DateTime?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([provider, providerId])
}

model Channel {
  id          String    @id @default(cuid())
  type        String    // email | telegram | slack | calendar | ...
  label       String?
  config      Json
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  threads     Thread[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Thread {
  id          String    @id @default(cuid())
  channel     Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId   String
  externalId  String?   // provider thread/conversation id
  subject     String?
  status      String    @default("open") // open | done | snoozed
  priority    String?   // low | normal | high
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]
  actions     Action[]
}

model Message {
  id            String   @id @default(cuid())
  thread        Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId      String
  direction     String   // inbound | outbound
  author        String?
  content       String
  metadata      Json?
  occurredAt    DateTime @default(now())
  createdAt     DateTime @default(now())
}

model Action {
  id            String    @id @default(cuid())
  thread        Thread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId      String
  type          String    // reply | schedule | create_ticket | etc.
  payload       Json
  status        String    @default("pending") // pending | approved | rejected | executing | done | failed
  result        Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  approval      Approval?
}

model Approval {
  id          String   @id @default(cuid())
  action      Action   @relation(fields: [actionId], references: [id], onDelete: Cascade)
  actionId    String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  status      String   @default("pending") // pending | approved | rejected
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  entity      String   // message | action | approval | job
  entityId    String
  event       String
  metadata    Json?
  createdAt   DateTime @default(now())
}
